<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Messages Dashboard</title>
    <link rel="stylesheet" href="/css/style.css">
</head>

<body class="admin">

<div class="dashboard-wrapper">

    <!-- HEADER -->
    <div class="dashboard-header">
        <h1>📩 Messages Dashboard</h1>

        <div class="top-actions">
            <a href="/" class="btn ghost">← Home</a>
            <a href="/logout" class="btn danger">Logout</a>
        </div>
    </div>

    <!-- STATS -->
    <div class="stats-grid">
        <div class="stat"><h2><%= stats?.total ?? 0 %></h2><p>Total</p></div>
        <div class="stat"><h2><%= stats?.today ?? 0 %></h2><p>Today</p></div>
        <div class="stat"><h2><%= stats?.week ?? 0 %></h2><p>Week</p></div>
        <div class="stat"><h2><%= stats?.month ?? 0 %></h2><p>Month</p></div>
    </div>

    <!-- TOAST -->
    <%- include('partials/toast') %>

    <!-- SEARCH -->
    <div class="search-box">
        <form action="/messages" method="GET">
            <input
                type="text"
                name="search"
                placeholder="Search messages..."
                value="<%= search || '' %>"
            />
            <button type="submit">Search</button>
        </form>
    </div>

    <!-- COUNT -->
    <div class="meta">
        Showing <b><%= totalMessages ?? 0 %></b> messages
    </div>

    <!-- CARDS -->
    <div class="grid">

        <% if (!messages || messages.length === 0) { %>
            <div class="empty">No messages found</div>
        <% } %>

        <% messages.forEach(msg => { %>

        <div class="card">

            <!-- TOP SECTION -->
            <div class="card-top">

                <div class="name">
                    <%= msg.firstName %> <%= msg.lastName %>
                </div>

                <!-- FIXED BUTTON GROUP -->
                <div class="actions">

                    <a href="/messages/edit/<%= msg._id %>" class="btn edit-btn">
                        ✏️ Edit
                    </a>

                    <button class="btn delete-btn"
                        onclick="openModal('<%= msg._id %>')">
                        🗑 Delete
                    </button>

                </div>

            </div>

            <!-- INFO -->
            <div class="info">
                <p>📧 <%= msg.email %></p>
                <% if (msg.phone) { %>
                    <p>📞 <%= msg.phone %></p>
                <% } %>
            </div>

            <!-- MESSAGE -->
            <div class="msg">
                <%= msg.message %>
            </div>

            <!-- TIME -->
            <div class="time">
                <%= new Date(msg.createdAt).toLocaleString() %>
            </div>

        </div>

        <% }) %>

    </div>

    <!-- PAGINATION -->
    <div class="pagination">
        <% for(let i = 1; i <= totalPages; i++) { %>
            <a class="page <%= i === currentPage ? 'active' : '' %>"
               href="/messages?page=<%= i %>&search=<%= search || '' %>">
                <%= i %>
            </a>
        <% } %>
    </div>

</div>

<!-- MODAL -->
<div id="deleteModal" class="modal">
    <div class="modal-box">
        <h2>Delete Message?</h2>
        <p>This action cannot be undone.</p>

        <div class="modal-actions">
            <form id="deleteForm" method="POST">
                <button class="btn danger">Yes Delete</button>
            </form>
            <button class="btn ghost" onclick="closeModal()">Cancel</button>
        </div>
    </div>
</div>

<script>
function openModal(id) {
    document.getElementById("deleteForm").action = "/messages/delete/" + id;
    document.getElementById("deleteModal").style.display = "flex";
}

function closeModal() {
    document.getElementById("deleteModal").style.display = "none";
}

window.onclick = (e) => {
    if (e.target.id === "deleteModal") closeModal();
};
</script>

</body>
</html>