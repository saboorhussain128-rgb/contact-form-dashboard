<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard - Messages</title>
    <link rel="stylesheet" href="/css/style.css">
</head>

<body class="admin">

    <h1>📩 Contact Messages</h1>

    <!-- TOP LINKS -->
    <div class="top-links">
        <a href="/">⬅ Back To Contact Form</a>
        |
        <a href="/logout">🚪 Logout</a>
    </div>

    <!-- NO DATA -->
    <% if (messages.length === 0) { %>
        <p class="no-data">No messages found.</p>
    <% } else { %>

        <!-- CARDS -->
        <div class="cards">

            <% messages.forEach(msg => { %>

                <div class="card">

                    <!-- DELETE BUTTON -->
                    <form action="/messages/delete/<%= msg._id %>" method="POST">
                        <button type="submit" class="delete-btn">Delete</button>
                    </form>

                    <!-- NAME -->
                    <h3><%= msg.firstName %> <%= msg.lastName %></h3>

                    <!-- EMAIL -->
                    <p>
                        <strong>Email:</strong>
                        <a class="email-link" href="mailto:<%= msg.email %>">
                            <%= msg.email %>
                        </a>
                    </p>

                    <!-- PHONE -->
                    <% if (msg.phone) { %>
                        <p>
                            <strong>Phone:</strong>
                            <a class="phone-link" href="tel:<%= msg.phone %>">
                                <%= msg.phone %>
                            </a>
                        </p>
                    <% } %>

                    <!-- MESSAGE -->
                    <p><%= msg.message %></p>

                    <!-- DATE -->
                    <small>
                        📅 <%= new Date(msg.createdAt).toLocaleString("en-US", {
                            weekday: 'short',
                            year: 'numeric',
                            month: 'short',
                            day: 'numeric',
                            hour: 'numeric',
                            minute: 'numeric'
                        }) %>
                    </small>

                </div>

            <% }) %>

        </div>

    <% } %>

</body>
</html>