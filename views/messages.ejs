<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard - Messages</title>

    <link rel="stylesheet" href="/css/style.css">
</head>

<body class="admin">

    <h1>📩 Contact Messages</h1>

    <!-- TOP LINKS -->
    <div class="top-links">
        <a href="/">⬅ Back To Contact Form</a>
        |
        <a href="/logout">🚪 Logout</a>
    </div>

    <!-- SEARCH -->
    <div style="text-align:center; margin-bottom:20px;">
        <form action="/messages" method="GET">

            <input
                type="text"
                name="search"
                placeholder="Search by name, email or message..."
                value="<%= search || '' %>"
                style="padding:10px; width:300px; border-radius:8px; border:none;"
            >

            <button type="submit">Search</button>
        </form>
    </div>

    <!-- TOTAL -->
    <div style="text-align:center; margin-bottom:20px;">
        <h3>Total Messages: <%= totalMessages %></h3>
    </div>

    <% if (messages.length === 0) { %>

        <p class="no-data">No messages found.</p>

    <% } else { %>

        <div class="cards">

            <% messages.forEach(msg => { %>

                <div class="card">

                    <form action="/messages/delete/<%= msg._id %>" method="POST">
                        <button class="delete-btn">Delete</button>
                    </form>

                    <h3><%= msg.firstName %> <%= msg.lastName %></h3>

                    <p>
                        <strong>Email:</strong>
                        <a class="email-link" href="mailto:<%= msg.email %>">
                            <%= msg.email %>
                        </a>
                    </p>

                    <% if (msg.phone) { %>
                        <p>
                            <strong>Phone:</strong>
                            <a class="phone-link" href="tel:<%= msg.phone %>">
                                <%= msg.phone %>
                            </a>
                        </p>
                    <% } %>

                    <p><%= msg.message %></p>

                    <small>
                        📅 <%= new Date(msg.createdAt).toLocaleString() %>
                    </small>

                </div>

            <% }) %>

        </div>

        <!-- PAGINATION -->
        <div style="text-align:center; margin-top:30px;">

            <% for(let i = 1; i <= totalPages; i++) { %>

                <a href="/messages?page=<%= i %>&search=<%= search || '' %>"
                   style="margin:5px; padding:8px 14px; background:#a855f7; color:white; border-radius:6px; text-decoration:none;">
                    <%= i %>
                </a>

            <% } %>

        </div>

    <% } %>

</body>
</html>