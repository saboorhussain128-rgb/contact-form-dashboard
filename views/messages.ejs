<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard - Messages</title>
    <link rel="stylesheet" href="/css/style.css">
</head>

<body class="admin">

    <h1>📩 Contact Messages</h1>

    <!-- DASHBOARD STATS -->
    <div class="dashboard-stats">

        <div class="stat-card">
            <h2><%= stats?.total || 0 %></h2>
            <p>Total Messages</p>
        </div>

        <div class="stat-card">
            <h2><%= stats?.today || 0 %></h2>
            <p>Today</p>
        </div>

        <div class="stat-card">
            <h2><%= stats?.week || 0 %></h2>
            <p>This Week</p>
        </div>

        <div class="stat-card">
            <h2><%= stats?.month || 0 %></h2>
            <p>This Month</p>
        </div>

    </div>

    <!-- TOP LINKS -->
    <div class="top-links">
        <a href="/">⬅ Back To Contact Form</a>
        |
        <a href="/logout">🚪 Logout</a>
    </div>

    <!-- TOAST -->
    <%- include('partials/toast') %>

    <!-- SEARCH -->
    <div style="text-align:center; margin-bottom:20px;">
        <form action="/messages" method="GET">
            <input
                type="text"
                name="search"
                placeholder="Search messages..."
                value="<%= search || '' %>"
            >
            <button type="submit">Search</button>
        </form>
    </div>

    <!-- TOTAL -->
    <div style="text-align:center; margin-bottom:20px;">
        <h3>Total Filtered Messages: <%= totalMessages %></h3>
    </div>

    <% if (!messages || messages.length === 0) { %>
        <p class="no-data">No messages found.</p>
    <% } else { %>

        <div class="cards">

            <% messages.forEach(msg => { %>

                <div class="card">

                    <div style="display:flex; justify-content:space-between; margin-bottom:10px;">

                        <a href="/messages/edit/<%= msg._id %>"
                           style="background:#3b82f6;color:white;padding:8px 12px;border-radius:6px;text-decoration:none;">
                            ✏️ Edit
                        </a>

                        <button
                            type="button"
                            class="delete-btn"
                            onclick="openModal('<%= msg._id %>')">
                            🗑 Delete
                        </button>

                    </div>

                    <h3><%= msg.firstName %> <%= msg.lastName %></h3>

                    <p>
                        <strong>Email:</strong>
                        <a href="mailto:<%= msg.email %>" class="email-link">
                            <%= msg.email %>
                        </a>
                    </p>

                    <% if (msg.phone) { %>
                        <p>
                            <strong>Phone:</strong>
                            <a href="tel:<%= msg.phone %>" class="phone-link">
                                <%= msg.phone %>
                            </a>
                        </p>
                    <% } %>

                    <p><%= msg.message %></p>

                    <small>
                        📅 <%= new Date(msg.createdAt).toLocaleString() %>
                    </small>

                </div>

            <% }) %>

        </div>

        <div style="text-align:center;margin-top:30px;">

            <% for(let i = 1; i <= totalPages; i++) { %>
                <a href="/messages?page=<%= i %>&search=<%= search || '' %>"
                   style="margin:5px;padding:8px 14px;background:#a855f7;color:white;border-radius:6px;text-decoration:none;">
                    <%= i %>
                </a>
            <% } %>

        </div>

    <% } %>

    <!-- DELETE MODAL -->
    <div id="deleteModal" class="modal">
        <div class="modal-content">

            <h2>⚠️ Confirm Delete</h2>
            <p>Are you sure you want to delete this message?</p>

            <div class="modal-actions">

                <form id="deleteForm" method="POST">
                    <button type="submit" class="danger-btn">Yes, Delete</button>
                </form>

                <button class="cancel-btn" onclick="closeModal()">Cancel</button>

            </div>

        </div>
    </div>

    <script>
        function openModal(id) {
            const modal = document.getElementById("deleteModal");
            const form = document.getElementById("deleteForm");
            form.action = "/messages/delete/" + id;
            modal.style.display = "flex";
        }

        function closeModal() {
            document.getElementById("deleteModal").style.display = "none";
        }

        window.onclick = function(event) {
            const modal = document.getElementById("deleteModal");
            if (event.target === modal) {
                modal.style.display = "none";
            }
        };
    </script>

</body>
</html>