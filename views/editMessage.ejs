<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Message</title>
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

    <h1>✏️ Edit Message</h1>

    <div style="text-align:center; margin-bottom:20px;">
        <a href="/messages" style="color:white; background:#6b7280; padding:8px 12px; border-radius:6px; text-decoration:none;">
            ⬅ Back to Messages
        </a>
    </div>

    <!-- EDIT CARD -->
    <div class="card" style="max-width:600px; margin:0 auto; padding:20px;">

        <form action="/messages/edit/<%= message._id %>" method="POST">

            <label>First Name</label>
            <input type="text" name="firstName" value="<%= message.firstName %>" required>

            <label>Last Name</label>
            <input type="text" name="lastName" value="<%= message.lastName %>" required>

            <label>Email</label>
            <input type="email" name="email" value="<%= message.email %>" required>

            <label>Phone</label>
            <input type="text" name="phone" value="<%= message.phone %>">

            <label>Message</label>
            <textarea name="message" rows="5" required><%= message.message %></textarea>

            <button type="submit" style="margin-top:15px; width:100%; background:#3b82f6;">
                Update Message
            </button>

        </form>

    </div>

</body>
</html>