<% const q = query || {}; %>

<% const toast =
    q.deleted ? { type: "success", msg: "Message deleted successfully" } :
    q.updated ? { type: "success", msg: "Message updated successfully" } :
    q.error === "notfound" ? { type: "error", msg: "Message not found" } :
    q.error === "server" ? { type: "error", msg: "Server error occurred" } :
    q.error === "delete" ? { type: "error", msg: "Failed to delete message" } :
    q.error === "update" ? { type: "error", msg: "Failed to update message" } :
    null;
%>

<% if (toast) { %>
    <div class="toast <%= toast.type %>">
        <%= toast.msg %>
    </div>
<% } %>