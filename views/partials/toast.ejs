<% const q = typeof query !== "undefined" ? query : {}; %>

<% if (q.deleted) { %>
    <div class="toast success">✅ Message deleted successfully</div>
<% } %>

<% if (q.updated) { %>
    <div class="toast success">✏️ Message updated successfully</div>
<% } %>

<% if (q.error === "notfound") { %>
    <div class="toast error">❌ Message not found</div>
<% } %>

<% if (q.error === "server") { %>
    <div class="toast error">⚠️ Server error occurred</div>
<% } %>