<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Contact Mission</title>
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

    <div class="container">

        <div class="left">
            <h1>Contact Us 🚀</h1>

            <form action="/contact" method="POST">

                <!-- First Name -->
                <input
                    type="text"
                    name="firstName"
                    placeholder="First Name"
                    value="<%= formData.firstName || '' %>"
                    required
                >

                <!-- Last Name -->
                <input
                    type="text"
                    name="lastName"
                    placeholder="Last Name"
                    value="<%= formData.lastName || '' %>"
                    required
                >

                <!-- Email -->
                <input
                    type="email"
                    name="email"
                    placeholder="Email"
                    value="<%= formData.email || '' %>"
                    required
                >

                <!-- Phone -->
                <input
                    type="text"
                    name="phone"
                    placeholder="Phone"
                    value="<%= formData.phone || '' %>"
                >

                <!-- Message -->
                <textarea
                    id="message"
                    name="message"
                    placeholder="Your Message"
                    maxlength="500"
                    required
                ><%= formData.message || '' %></textarea>

                <!-- Character Counter -->
                <div class="counter">
                    <span id="charCount">0</span>/500
                </div>

                <button type="submit">
                    Send it to the moon 🚀
                </button>

            </form>

            <% if (success === "true") { %>
                <p class="success">
                    Message sent successfully 🚀
                </p>
            <% } %>

            <% if (success === "false") { %>
                <p class="error">
                    Something went wrong ❌
                </p>
            <% } %>

            <% if (error) { %>
                <p class="error">
                    <%= error %>
                </p>
            <% } %>

        </div>

        <div class="right">
            <img src="/image/astronaut.png" alt="astronaut">
        </div>

    </div>

    <!-- Frontend JavaScript -->
    <script src="/js/main.js"></script>

</body>
</html>