<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Get In Touch</title>

    <link rel="stylesheet" href="/css/style.css">
</head>

<body class="contact-page">

    <div class="page-wrapper">

        <div class="glass-card">

            <!-- LEFT SECTION -->
            <div class="left">

                <h1>
                    Get in <span>touch</span>
                </h1>

                <p class="subtitle">
                    Reach out and let's create something amazing together.
                </p>

                <!-- SUCCESS MESSAGE -->
                <% if (success === "true") { %>
                    <div class="success-box">
                        ✅ Message sent successfully
                    </div>
                <% } %>

                <!-- ERROR MESSAGE -->
                <% if (error) { %>
                    <div class="error-box">
                        ❌ <%= error %>
                    </div>
                <% } %>

                <!-- CONTACT FORM -->
                <form action="/contact" method="POST">

                    <div class="row">
                        <input
                            type="text"
                            name="firstName"
                            placeholder="First Name"
                            value="<%= formData?.firstName || '' %>"
                            required
                        >

                        <input
                            type="text"
                            name="lastName"
                            placeholder="Last Name"
                            value="<%= formData?.lastName || '' %>"
                            required
                        >
                    </div>

                    <div class="row">
                        <input
                            type="email"
                            name="email"
                            placeholder="Email"
                            value="<%= formData?.email || '' %>"
                            required
                        >

                        <input
                            type="text"
                            name="phone"
                            placeholder="Phone"
                            value="<%= formData?.phone || '' %>"
                        >
                    </div>

                    <textarea
                        name="message"
                        maxlength="500"
                        placeholder="Write your message..."
                        required
                    ><%= formData?.message || '' %></textarea>

                    <button type="submit">
                        Send Message 🚀
                    </button>

                </form>

                <!-- ADMIN SECTION -->
                <div class="admin-actions">

                    <% if (isAuth) { %>

                        <div class="admin-buttons">

                            <a href="/messages" class="btn ghost">
                                📩 Open Dashboard
                            </a>

                            <a href="/logout" class="btn danger">
                                🚪 Logout
                            </a>

                        </div>

                    <% } else { %>

                        <div class="admin-buttons">

                            <a href="/login" class="btn ghost">
                                🔐 Admin Login
                            </a>

                        </div>

                    <% } %>

                </div>

            </div>

            <!-- RIGHT SECTION -->
            <div class="right">

                <img
                    src="/image/astronaut.png"
                    alt="Astronaut"
                >

            </div>

        </div>

    </div>

    <script src="/js/main.js"></script>

</body>
</html>